# Mac (Homebrew PostgreSQL): DATABASE_URL=postgresql://$(whoami)@localhost:5432/treasurenet
# Docker:                   DATABASE_URL=postgresql://treasurenet:treasurenet@localhost:5432/treasurenet
DATABASE_URL=postgresql://tata@localhost:5432/treasurenet

# ─── Redis (optional for local dev) ──────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Stellar / Soroban ────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ─── JWT ──────────────────────────────────────
JWT_SECRET=treasurenet-local-dev-only
JWT_EXPIRATION=7d

# ─── App ──────────────────────────────────────
PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development
