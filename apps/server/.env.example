# Mac (Homebrew PostgreSQL): DATABASE_URL=postgresql://$(whoami)@localhost:5432/treasurenet
# Docker:                   DATABASE_URL=postgresql://treasurenet:treasurenet@localhost:5432/treasurenet
DATABASE_URL=postgresql://tata@localhost:5432/treasurenet

# ─── Redis (optional for local dev) ──────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Stellar / Soroban ────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ─── JWT ──────────────────────────────────────
JWT_SECRET=treasurenet-local-dev-only
JWT_EXPIRATION=7d

# ─── App ──────────────────────────────────────
PORT=7755
CORS_ORIGIN=http://localhost:7777
NODE_ENV=development

# ─── Admin / Server ───────────────────────────
ADMIN_KEY=treasurenet-admin-dev
SERVER_SECRET_KEY=your-stellar-secret-key-here

# ─── Contract Addresses ───────────────────────
SBT_CONTRACT_ID=CBUY3UF2MZDDCAHVERSEETXEXCBTPHMU4HBSMIGK7COETHMZSWI4F464
REGISTRY_CONTRACT_ID=CBAHM6A7LJLDV3RK2VPQCIYCHPDTHRAZD5ECDYSGTAHBLEOJBLBFKTMQ
TREASURE_HUNT_CONTRACT_ID=CDFDKHSRNDN45JAQEQUJHQTNNOI7ALJHSCKDSS3WXFXA7UA2GQVB5ZUU

# ─── Platform ────────────────────────────────
PLATFORM_WALLET_ADDRESS=your-platform-stellar-address
